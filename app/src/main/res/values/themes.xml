<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.UPIPaymentAlert" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/jigar_orange_start</item>
        <item name="colorPrimaryVariant">@color/jigar_orange_end</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/jigar_accent</item>
        <item name="colorSecondaryVariant">@color/jigar_accent</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/jigar_bg</item>
        
        <item name="android:windowBackground">@color/jigar_bg</item>
        <item name="android:textColorPrimary">@color/jigar_text_primary</item>
        <item name="android:textColorSecondary">@color/jigar_text_secondary</item>
    </style>
</resources>